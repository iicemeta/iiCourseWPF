---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="新闻动态" description="iiCourse 最新资讯和博客文章">
  <Navigation />
  
  <main class="pt-24 pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 页面标题 -->
      <div class="text-center mb-16">
        <h1 class="section-title mb-4">📰 新闻<span class="gradient-text">动态</span></h1>
        <p class="text-xl text-base-content/70">
          最新资讯、开发日志和使用技巧
        </p>
      </div>
      
      <!-- 文章列表 -->
      <div class="space-y-8">
        {sortedPosts.map((post) => (
          <article class="card bg-base-100 shadow-lg hover:shadow-xl transition-shadow">
            <a href={`/news/${post.id}`} class="block">
              <div class="card-body">
                <div class="flex items-center gap-4 mb-4 text-sm text-base-content/50">
                  <span>
                    {post.data.pubDate.toLocaleDateString('zh-CN', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </span>
                  <span>·</span>
                  <span>{post.data.author}</span>
                </div>
                
                <h2 class="card-title text-2xl hover:text-primary transition-colors">
                  {post.data.title}
                </h2>
                
                <p class="text-base-content/70 mb-4 line-clamp-2">
                  {post.data.description}
                </p>
                
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="badge badge-outline">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
