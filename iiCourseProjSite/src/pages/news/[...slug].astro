---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <Navigation />

  <main class="pt-24 pb-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 面包屑 -->
      <div class="breadcrumbs text-sm mb-8">
        <ul>
          <li><a href="/" class="hover:text-primary">首页</a></li>
          <li><a href="/news" class="hover:text-primary">新闻</a></li>
          <li class="text-base-content truncate max-w-xs">{post.data.title}</li>
        </ul>
      </div>

      <!-- 文章头部 -->
      <header class="mb-8">
        <div class="flex items-center gap-4 mb-4 text-sm text-base-content/50">
          <span>
            {post.data.pubDate.toLocaleDateString('zh-CN', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </span>
          <span>·</span>
          <span>{post.data.author}</span>
        </div>

        <h1 class="text-4xl font-bold text-base-content mb-4">{post.data.title}</h1>

        <p class="text-xl text-base-content/70">{post.data.description}</p>

        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {post.data.tags.map((tag) => (
              <span class="badge badge-primary badge-outline">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <!-- 文章内容 -->
      <article class="prose prose-lg max-w-none">
        <Content />
      </article>

      <!-- 返回按钮 -->
      <div class="mt-12 pt-8 border-t border-base-300">
        <a href="/news" class="btn btn-ghost gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          返回新闻列表
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
