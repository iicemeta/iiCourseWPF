---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const lastUpdated = '2025年3月12日';

const sections = [
  {
    id: 'acceptance',
    title: '接受条款',
    content: '下载或使用 iiCourse，即表示你同意这些条款。如果不同意，可以卸载应用，我们不会拦着你。'
  },
  {
    id: 'license',
    title: '使用许可',
    content: '我们授予你个人、非独占、不可转让的许可来使用本应用。你可以：',
    list: [
      '在个人设备上安装和使用',
      '为学习目的使用所有功能',
      '向同学推荐（这是帮我们的忙）'
    ],
    cannot: '但不能：',
    cannotList: [
      '倒卖或商业化应用',
      '反编译或修改代码后声称是自己的',
      '用应用做违法的事情'
    ]
  },
  {
    id: 'account',
    title: '账号安全',
    content: '你需要用学校的 CAS 账号登录。记住：',
    list: [
      '保管好你的密码',
      '不要在公共电脑上保存登录状态',
      '发现异常及时改密码'
    ]
  },
  {
    id: 'disclaimer',
    title: '免责声明',
    content: '我们会尽力保证数据准确，但：',
    list: [
      '教务系统数据以学校官方为准',
      '因网络问题导致的数据延迟我们不负责',
      '考试前请再次确认官方课表，别赖我们'
    ]
  },
  {
    id: 'opensource',
    title: '开源协议',
    content: 'iiCourse 是开源软件，基于 MIT 协议发布。你可以自由查看、使用、修改源代码，但要保留版权声明。'
  },
  {
    id: 'updates',
    title: '更新与维护',
    content: '我们会不定期发布更新，修复 bug 或添加功能。但：',
    list: [
      '不保证永久维护（毕竟我们是学生）',
      '旧版本可能停止支持',
      '建议保持更新以获得最佳体验'
    ]
  },
  {
    id: 'termination',
    title: '终止使用',
    content: '如果你违反这些条款，我们可以终止你的使用权限。当然，你也可以随时卸载，没有违约金。'
  },
  {
    id: 'contact',
    title: '联系我们',
    content: '对条款有疑问？通过以下方式联系：',
    list: [
      'GitHub Issues: github.com/iicemeta/iiCourseWPF',
      'Telegram 群组: t.me/iicoursecom',
      'Telegram 频道: t.me/iicourse'
    ]
  }
];
---

<Layout title="使用条款" description="iiCourse 使用条款 - 使用本应用前请阅读">
  <Navigation />
  
  <main class="relative z-10 flex-1">
    <!-- Hero Section -->
    <section class="pt-32 pb-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-400/10 via-purple-400/5 to-pink-400/10"></div>
      
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="text-center">
          <span class="badge badge-glass mb-4">The Fine Print</span>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
            使用条款
          </h1>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            比用户协议好读一百倍
          </p>
          <p class="text-sm text-gray-500 mt-4">
            最后更新：{lastUpdated}
          </p>
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="py-12 pb-24">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="glass-panel p-8 md:p-12 space-y-12">
          {sections.map((section, index) => (
            <div class="terms-section" id={section.id}>
              <div class="flex items-start gap-4">
                <span class="flex-shrink-0 w-10 h-10 rounded-xl bg-gradient-to-br from-blue-400 to-purple-400 flex items-center justify-center text-white font-bold text-sm">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <div class="flex-1">
                  <h2 class="text-2xl font-bold text-gray-900 mb-4">
                    {section.title}
                  </h2>
                  <p class="text-gray-600 leading-relaxed mb-4">
                    {section.content}
                  </p>
                  {section.list && (
                    <ul class="space-y-2 mb-4">
                      {section.list.map(item => (
                        <li class="flex items-start gap-3 text-gray-600">
                          <span class="w-5 h-5 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                              <polyline points="20 6 9 17 4 12"/>
                            </svg>
                          </span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                  {section.cannot && (
                    <p class="text-gray-600 mb-2">{section.cannot}</p>
                  )}
                  {section.cannotList && (
                    <ul class="space-y-2">
                      {section.cannotList.map(item => (
                        <li class="flex items-start gap-3 text-gray-600">
                          <span class="w-5 h-5 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                              <line x1="18" y1="6" x2="6" y2="18"/>
                              <line x1="6" y1="6" x2="18" y2="18"/>
                            </svg>
                          </span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </div>
            </div>
          ))}

          <!-- Summary Box -->
          <div class="mt-12 p-6 rounded-2xl bg-gradient-to-br from-blue-50 to-purple-50 border border-blue-200">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                  <polyline points="10 9 9 9 8 9"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 mb-2">太长不看版</h3>
                <p class="text-gray-600">
                  正常使用没问题，别干坏事，数据以学校为准。我们是开源项目，用爱发电。
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Back Link -->
        <div class="mt-8 text-center">
          <a href="/" class="inline-flex items-center gap-2 text-gray-500 hover:text-orange-500 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            返回首页
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .terms-section:not(:last-child) {
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    padding-bottom: 2rem;
  }
</style>
