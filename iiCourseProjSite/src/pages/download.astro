---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { downloadConfig } from '../config/download.config';

const {
  pageTitle,
  pageSubtitle,
  currentVersion,
  releaseDate,
  githubRepo,
  downloadCategories,
  downloadButton,
  changelogButton,
  downloadNote,
  systemRequirementsTitle,
  systemRequirements,
  installStepsTitle,
  installSteps,
  faqTitle,
  faqItems
} = downloadConfig;
---

<Layout title="下载" description="下载 iiCourse 最新版本">
  <Navigation />

  <main class="pt-32 pb-16 relative z-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 页面标题 -->
      <div class="text-center mb-16">
        <span class="badge badge-glass mb-4">免费下载</span>
        <h1 class="section-title mb-4">
          <span class="gradient-text-warm">{pageTitle}</span>
        </h1>
        <p class="text-xl text-gray-600">
          {pageSubtitle}
        </p>
      </div>

      <!-- 版本信息卡片 -->
      <div class="glass-panel overflow-hidden mb-8">
        <div class="relative bg-gradient-to-br from-orange-400 to-pink-400 p-8 text-white text-center overflow-hidden">
          <div class="absolute top-0 left-0 w-40 h-40 bg-white/20 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
          <div class="absolute bottom-0 right-0 w-40 h-40 bg-white/20 rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>
          
          <div class="relative">
            <div class="text-sm opacity-90 mb-2 font-medium">最新版本</div>
            <div class="text-6xl font-bold mb-2">v{currentVersion}</div>
            <div class="text-sm opacity-90">发布于 {releaseDate}</div>
          </div>
        </div>
      </div>

      <!-- 推荐下载按钮 -->
      <div class="text-center mb-12">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6">
          <a
            href={downloadButton.href}
            class="btn btn-primary btn-lg w-full sm:w-auto gap-3 group"
            download
          >
            <span class="text-2xl group-hover:scale-110 transition-transform">{downloadButton.icon}</span>
            <span>{downloadButton.text}</span>
          </a>
          <a
            href={changelogButton.href}
            class="btn btn-secondary btn-lg w-full sm:w-auto"
          >
            {changelogButton.text}
          </a>
        </div>

        <div class="inline-flex items-center gap-2 tag">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="text-gray-600">{downloadNote}</span>
        </div>

        <!-- 网络异常提示 -->
        <div class="mt-6 p-4 bg-amber-50 rounded-xl border border-amber-100 max-w-lg mx-auto">
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-500 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
              <line x1="12" y1="9" x2="12" y2="13"></line>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            <div class="text-left">
              <p class="text-sm text-amber-900 font-medium">位于中国大陆地区？</p>
              <p class="text-sm text-amber-700 mt-1">如果下载缓慢或失败，请使用下方备用下载按钮</p>
            </div>
          </div>
        </div>

        <!-- 备用下载按钮 -->
        <div class="mt-4">
          <a
            href={downloadButton.mirrorHref}
            class="inline-flex items-center gap-2 text-sm text-amber-600 hover:text-amber-800 transition-colors"
            download
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            备用下载（中国大陆网络）
          </a>
        </div>
      </div>

      <!-- 多版本下载选项 -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-2 text-center">选择你的版本</h2>
        <p class="text-center text-gray-600 mb-8">不确定？选第一个就对了</p>
        
        <div class="space-y-6">
          {downloadCategories.map((category, catIndex) => (
            <div class="glass-panel overflow-hidden">
              <div class="bg-gradient-to-r from-gray-50 to-gray-100 px-6 py-4 border-b border-gray-200">
                <h3 class="font-bold text-gray-900 text-lg">{category.title}</h3>
                <p class="text-sm text-gray-600 mt-1">{category.description}</p>
              </div>
              <div class="divide-y divide-gray-100">
                {category.versions.map((version) => (
                  <div class="flex items-center justify-between p-4 sm:p-6 hover:bg-gray-50/50 transition-colors">
                    <div class="flex items-center gap-4">
                      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-orange-100 to-pink-100 flex items-center justify-center text-xl">
                        {version.arch === 'x64' && '💻'}
                        {version.arch === 'x86' && '🖥️'}
                        {version.arch === 'arm64' && '📱'}
                        {version.arch === 'any' && '⚡'}
                      </div>
                      <div>
                        <div class="flex items-center gap-2">
                          <span class="font-bold text-gray-900">{version.name}</span>
                          {version.recommended && (
                            <span class="px-2 py-0.5 bg-green-100 text-green-700 text-xs font-medium rounded-full">
                              推荐
                            </span>
                          )}
                          {version.requiresDotNet && (
                            <span class="px-2 py-0.5 bg-blue-100 text-blue-700 text-xs font-medium rounded-full">
                              需 .NET 9
                            </span>
                          )}
                        </div>
                        <p class="text-sm text-gray-600 mt-0.5">{version.description}</p>
                      </div>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="text-sm text-gray-500 hidden sm:block">{version.size}</span>
                      <a
                        href={version.href}
                        class="btn btn-primary btn-sm"
                        download
                      >
                        下载
                      </a>
                      <a
                        href={version.mirrorHref}
                        class="text-xs text-amber-600 hover:text-amber-800 underline"
                        download
                        title="中国大陆网络备用"
                      >
                        备用
                      </a>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>

        <!-- .NET 9 下载提示 -->
        <div class="mt-6 p-4 bg-blue-50 rounded-xl border border-blue-100">
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="16" x2="12" y2="12"></line>
              <line x1="12" y1="8" x2="12.01" y2="8"></line>
            </svg>
            <div>
              <p class="text-sm text-blue-900 font-medium">需要 .NET 9 运行时？</p>
              <p class="text-sm text-blue-700 mt-1">
                如果你选择框架依赖版本，请先
                <a href="https://dotnet.microsoft.com/download/dotnet/9.0" target="_blank" rel="noopener noreferrer" class="underline hover:text-blue-900">
                  下载安装 .NET 9 运行时
                </a>
              </p>
            </div>
          </div>
        </div>

        <!-- GitHub Release 链接 -->
        <div class="mt-4 text-center">
          <a 
            href={`https://github.com/${githubRepo}/releases`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            查看 GitHub 上的所有版本
          </a>
        </div>
      </div>

      <!-- 系统要求 -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">{systemRequirementsTitle}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {systemRequirements.map((req) => (
            <div class="glass rounded-2xl p-6 text-center hover:scale-105 transition-transform">
              <div class="text-4xl mb-3">{req.icon}</div>
              <h3 class="font-bold text-gray-900 mb-1">{req.title}</h3>
              <p class="text-sm text-gray-600">{req.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- 安装步骤 -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">{installStepsTitle}</h2>
        <div class="space-y-4">
          {installSteps.map((item, index) => (
            <div class="glass rounded-2xl p-6 flex items-start gap-5 group hover:shadow-lg transition-all">
              <div class="step-number flex-shrink-0 group-hover:scale-110 transition-transform">
                {item.step}
              </div>
              <div>
                <h3 class="font-bold text-gray-900 text-lg mb-1">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- 常见问题 -->
      <div class="glass-panel">
        <div class="p-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">{faqTitle}</h2>
          <div class="space-y-6">
            {faqItems.map((item, index) => (
              <div class="border-b border-gray-200/50 last:border-0 pb-6 last:pb-0">
                <h3 class="font-bold text-gray-900 mb-2 flex items-center gap-2">
                  <span class="w-6 h-6 rounded-full bg-orange-100 text-orange-500 flex items-center justify-center text-xs font-bold">
                    {index + 1}
                  </span>
                  {item.question}
                </h3>
                <p class="text-gray-600 pl-8">{item.answer}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
