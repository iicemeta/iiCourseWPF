---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const currentVersion = '1.7.200';
const releaseDate = '2026-03-11';

const systemRequirements = [
  { icon: '🪟', title: '操作系统', desc: 'Windows 10/11 (64位)' },
  { icon: '💻', title: '运行环境', desc: '.NET 9 Runtime' },
  { icon: '📦', title: '安装包大小', desc: '约 26 MB' },
  { icon: '🔌', title: '网络', desc: '需要校园网或 VPN' },
];

const installSteps = [
  { step: 1, title: '下载安装包', desc: '点击上方按钮下载最新版本' },
  { step: 2, title: '运行安装程序', desc: '双击下载的 .exe 文件' },
  { step: 3, title: '完成安装', desc: '按照向导完成安装' },
  { step: 4, title: '开始使用', desc: '打开应用，使用学号登录' },
];
---

<Layout title="下载" description="下载 iiCourse 最新版本">
  <Navigation />
  
  <main class="pt-24 pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 页面标题 -->
      <div class="text-center mb-16">
        <h1 class="section-title mb-4">⬇️ 下载<span class="gradient-text">应用</span></h1>
        <p class="text-xl text-gray-600">
          免费下载 iiCourse，让教务管理更简单
        </p>
      </div>
      
      <!-- 下载卡片 -->
      <div class="bg-white rounded-3xl shadow-2xl overflow-hidden mb-12">
        <div class="bg-gradient-to-br from-primary to-secondary p-8 text-white text-center">
          <div class="text-sm opacity-80 mb-2">最新版本</div>
          <div class="text-5xl font-bold mb-2">v{currentVersion}</div>
          <div class="text-sm opacity-80">发布于 {releaseDate}</div>
        </div>
        
        <div class="p-8">
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
            <a 
              href="#" 
              class="w-full sm:w-auto px-8 py-4 bg-primary text-white font-bold rounded-xl 
                     hover:bg-opacity-90 transition-all flex items-center justify-center space-x-2"
            >
              <span class="text-2xl">🪟</span>
              <span>下载 Windows 版</span>
            </a>
            <a 
              href="/updates" 
              class="w-full sm:w-auto px-8 py-4 border-2 border-gray-200 text-gray-700 font-semibold 
                     rounded-xl hover:border-primary hover:text-primary transition-all"
            >
              查看更新日志
            </a>
          </div>
          
          <div class="text-center text-sm text-gray-500">
            <p>完全免费 · 开源透明 · 本地运行</p>
          </div>
        </div>
      </div>
      
      <!-- 系统要求 -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">💻 系统要求</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {systemRequirements.map((req) => (
            <div class="bg-white rounded-xl shadow-lg p-6 text-center">
              <div class="text-4xl mb-3">{req.icon}</div>
              <h3 class="font-semibold text-gray-900 mb-1">{req.title}</h3>
              <p class="text-sm text-gray-600">{req.desc}</p>
            </div>
          ))}
        </div>
      </div>
      
      <!-- 安装步骤 -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">📝 安装步骤</h2>
        <div class="space-y-4">
          {installSteps.map((item) => (
            <div class="flex items-start space-x-4 bg-white rounded-xl shadow-lg p-6">
              <div class="w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center font-bold flex-shrink-0">
                {item.step}
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <!-- 常见问题 -->
      <div class="bg-gray-50 rounded-2xl p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">❓ 常见问题</h2>
        <div class="space-y-6">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">应用安全吗？</h3>
            <p class="text-gray-600">完全安全。应用完全本地运行，不会上传任何数据到第三方服务器。源代码开源，可审计。</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">需要联网吗？</h3>
            <p class="text-gray-600">需要连接校园网或使用 VPN 访问教务系统。查询操作需要实时连接学校服务器。</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">会保存密码吗？</h3>
            <p class="text-gray-600">密码可以选择保存到本地（加密存储），也可以每次手动输入，完全由你决定。</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">如何更新？</h3>
            <p class="text-gray-600">应用会自动检查更新，也可以在设置中手动检查。更新时会保留所有配置。</p>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
