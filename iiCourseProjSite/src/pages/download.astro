---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { downloadConfig } from '../config/download.config';

const {
  pageTitle,
  pageSubtitle,
  currentVersion,
  releaseDate,
  downloadButton,
  changelogButton,
  downloadNote,
  systemRequirementsTitle,
  systemRequirements,
  installStepsTitle,
  installSteps,
  faqTitle,
  faqItems
} = downloadConfig;
---

<Layout title="下载" description="下载 iiCourse 最新版本">
  <Navigation />

  <main class="pt-24 pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 页面标题 -->
      <div class="text-center mb-16">
        <h1 class="section-title mb-4">⬇️ {pageTitle.slice(0, 2)}<span class="gradient-text">{pageTitle.slice(2)}</span></h1>
        <p class="text-xl text-base-content/70">
          {pageSubtitle}
        </p>
      </div>

      <!-- 下载卡片 -->
      <div class="card bg-base-100 shadow-2xl overflow-hidden mb-12">
        <div class="bg-gradient-to-br from-primary to-secondary p-8 text-white text-center">
          <div class="text-sm opacity-80 mb-2">最新版本</div>
          <div class="text-5xl font-bold mb-2">v{currentVersion}</div>
          <div class="text-sm opacity-80">发布于 {releaseDate}</div>
        </div>

        <div class="card-body">
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
            <a
              href={downloadButton.href}
              class="btn btn-primary btn-lg w-full sm:w-auto gap-2"
            >
              <span class="text-2xl">{downloadButton.icon}</span>
              <span>{downloadButton.text}</span>
            </a>
            <a
              href={changelogButton.href}
              class="btn btn-outline btn-lg w-full sm:w-auto"
            >
              {changelogButton.text}
            </a>
          </div>

          <div class="text-center text-sm text-base-content/50">
            <p>{downloadNote}</p>
          </div>
        </div>
      </div>

      <!-- 系统要求 -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-base-content mb-6 text-center">💻 {systemRequirementsTitle}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {systemRequirements.map((req) => (
            <div class="card bg-base-100 shadow-lg">
              <div class="card-body items-center text-center">
                <div class="text-4xl mb-3">{req.icon}</div>
                <h3 class="card-title text-base">{req.title}</h3>
                <p class="text-sm text-base-content/70">{req.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- 安装步骤 -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-base-content mb-6 text-center">📝 {installStepsTitle}</h2>
        <div class="space-y-4">
          {installSteps.map((item) => (
            <div class="card bg-base-100 shadow-lg">
              <div class="card-body flex-row items-start gap-4">
                <div class="w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center font-bold flex-shrink-0">
                  {item.step}
                </div>
                <div>
                  <h3 class="font-semibold text-base-content">{item.title}</h3>
                  <p class="text-base-content/70">{item.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- 常见问题 -->
      <div class="card bg-base-200">
        <div class="card-body">
          <h2 class="card-title text-2xl mb-6">❓ {faqTitle}</h2>
          <div class="space-y-6">
            {faqItems.map((item) => (
              <div>
                <h3 class="font-semibold text-base-content mb-2">{item.question}</h3>
                <p class="text-base-content/70">{item.answer}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
