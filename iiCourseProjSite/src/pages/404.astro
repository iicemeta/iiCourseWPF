---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="页面未找到" description="抱歉，您访问的页面不存在">
  <Navigation />

  <main class="flex-1 flex items-center justify-center min-h-[70vh] pt-20 pb-20 relative overflow-hidden">
    <!-- 背景装饰 -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- 大圆装饰 -->
      <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full bg-gradient-to-br from-primary/20 to-secondary/10 blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-80 h-80 rounded-full bg-gradient-to-tr from-accent/20 to-primary/10 blur-3xl"></div>

      <!-- 浮动元素 -->
      <div class="absolute top-1/4 left-1/4 w-16 h-16 bg-primary/10 rounded-2xl rotate-12 animate-float"></div>
      <div class="absolute top-1/3 right-1/4 w-12 h-12 bg-secondary/20 rounded-full animate-float" style="animation-delay: 1s;"></div>
      <div class="absolute bottom-1/3 left-1/3 w-20 h-20 bg-accent/10 rounded-xl -rotate-6 animate-float" style="animation-delay: 2s;"></div>

      <!-- 404 数字背景 -->
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none">
        <span class="text-[20rem] md:text-[30rem] font-black text-gray-100/50">404</span>
      </div>
    </div>

    <!-- 内容区域 -->
    <div class="relative z-10 text-center px-4 max-w-2xl mx-auto">
      <!-- 错误图标 -->
      <div class="mb-8">
        <div class="inline-flex items-center justify-center w-32 h-32 rounded-full bg-gradient-to-br from-primary to-secondary shadow-2xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="8" y1="15" x2="16" y2="15"></line>
            <line x1="9" y1="9" x2="9.01" y2="9"></line>
            <line x1="15" y1="9" x2="15.01" y2="9"></line>
          </svg>
        </div>
      </div>

      <!-- 标题 -->
      <h1 class="text-5xl md:text-7xl font-black mb-4">
        <span class="gradient-text">404</span>
      </h1>

      <!-- 副标题 -->
      <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-4">
        页面走丢了
      </h2>

      <!-- 描述 -->
      <p class="text-lg text-gray-600 mb-8 max-w-md mx-auto">
        抱歉，您访问的页面不存在或已被移除。
        <br>
        就像忘记带课本一样尴尬 😅
      </p>

      <!-- 操作按钮 -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary text-lg px-8 py-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
          返回首页
        </a>
        <a href="/features" class="btn-secondary text-lg px-8 py-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
            <polyline points="2 17 12 22 22 17"></polyline>
            <polyline points="2 12 12 17 22 12"></polyline>
          </svg>
          查看功能
        </a>
      </div>

      <!-- 趣味提示 -->
      <div class="mt-12 p-6 bg-white/80 backdrop-blur-sm rounded-2xl shadow-lg border border-gray-100">
        <p class="text-gray-500 text-sm">
          💡 提示：您也可以尝试使用导航栏查找所需内容
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(5deg);
    }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
</style>
