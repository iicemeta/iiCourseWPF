---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import ClassroomList from '../../components/classrooms/ClassroomList.vue';
---

<Layout title="空教室查询演示" description="查看空教室查询功能演示">
  <Navigation />
  
  <main class="pt-24 pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 面包屑 -->
      <div class="breadcrumbs text-sm mb-8">
        <ul>
          <li><a href="/" class="hover:text-primary">首页</a></li>
          <li><a href="/features" class="hover:text-primary">功能</a></li>
          <li class="text-base-content">空教室</li>
        </ul>
      </div>
      
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-base-content mb-4">🏫 空教室查询</h1>
        <p class="text-lg text-base-content/70">
          查找空闲教室，支持按教学楼、日期、节次筛选。自习好去处，一键找到。
        </p>
      </div>
      
      <!-- 功能亮点 -->
      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <div class="card bg-green-50 border border-green-200">
          <div class="card-body">
            <div class="text-2xl mb-2">🔍</div>
            <h3 class="card-title text-base">快速查找</h3>
            <p class="text-sm text-base-content/70">多条件筛选，精准定位</p>
          </div>
        </div>
        <div class="card bg-blue-50 border border-blue-200">
          <div class="card-body">
            <div class="text-2xl mb-2">🏢</div>
            <h3 class="card-title text-base">教学楼筛选</h3>
            <p class="text-sm text-base-content/70">按教学楼快速定位</p>
          </div>
        </div>
        <div class="card bg-orange-50 border border-orange-200">
          <div class="card-body">
            <div class="text-2xl mb-2">⏰</div>
            <h3 class="card-title text-base">节次选择</h3>
            <p class="text-sm text-base-content/70">精确到具体时间段</p>
          </div>
        </div>
      </div>
      
      <!-- 空教室列表组件 -->
      <ClassroomList client:load />
    </div>
  </main>
  
  <Footer />
</Layout>
