---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="用户资料显示" description="查看用户信息功能演示">
  <Navigation />
  
  <main class="pt-24 pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 面包屑 -->
      <div class="breadcrumbs text-sm mb-8">
        <ul>
          <li><a href="/" class="hover:text-primary">首页</a></li>
          <li><a href="/features" class="hover:text-primary">功能</a></li>
          <li class="text-base-content">用户信息</li>
        </ul>
      </div>
      
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-base-content mb-4">👤 用户信息</h1>
        <p class="text-lg text-base-content/70">
          查看个人资料和校园卡信息，余额、消费记录一目了然。
        </p>
      </div>
      
      <!-- 用户信息卡片 -->
      <div class="card bg-base-100 shadow-xl overflow-hidden mb-8">
        <div class="bg-gradient-to-r from-primary to-secondary p-8 text-white">
          <div class="flex items-center gap-6">
            <div class="w-24 h-24 bg-white/20 rounded-full flex items-center justify-center text-5xl">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold">小涵</h2>
              <p class="opacity-90">艺术传媒学院 · 视觉传达设计 · 2023级</p>
              <p class="text-sm opacity-75 mt-1">学号: 2023020088</p>
            </div>
          </div>
        </div>
        
        <div class="card-body">
          <div class="grid md:grid-cols-2 gap-8">
            <!-- 基本信息 -->
            <div>
              <h3 class="text-lg font-semibold text-base-content mb-4">基本信息</h3>
              <div class="space-y-3">
                <div class="flex justify-between py-2 border-b border-base-300">
                  <span class="text-base-content/50">姓名</span>
                  <span class="font-medium">小涵</span>
                </div>
                <div class="flex justify-between py-2 border-b border-base-300">
                  <span class="text-base-content/50">性别</span>
                  <span class="font-medium">女</span>
                </div>
                <div class="flex justify-between py-2 border-b border-base-300">
                  <span class="text-base-content/50">民族</span>
                  <span class="font-medium">汉族</span>
                </div>
                <div class="flex justify-between py-2 border-b border-base-300">
                  <span class="text-base-content/50">出生日期</span>
                  <span class="font-medium">2005-06-15</span>
                </div>
                <div class="flex justify-between py-2 border-b border-base-300">
                  <span class="text-base-content/50">身份证号</span>
                  <span class="font-medium">370***********1234</span>
                </div>
              </div>
            </div>
            
            <!-- 校园卡信息 -->
            <div>
              <h3 class="text-lg font-semibold text-base-content mb-4">校园卡信息</h3>
              <div class="card bg-gradient-to-br from-orange-50 to-yellow-50 border border-orange-200">
                <div class="card-body">
                  <div class="flex items-center justify-between mb-4">
                    <span class="text-base-content/70">当前余额</span>
                    <span class="text-3xl font-bold text-primary">¥ 128.50</span>
                  </div>
                  <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                      <span class="text-base-content/50">卡号</span>
                      <span>6222 **** **** 8888</span>
                    </div>
                    <div class="flex justify-between">
                      <span class="text-base-content/50">状态</span>
                      <span class="text-success">正常</span>
                    </div>
                  </div>
                </div>
              </div>
              
              <h4 class="font-semibold text-base-content mt-6 mb-3">最近消费</h4>
              <div class="space-y-2">
                <div class="flex items-center justify-between py-2 text-sm">
                  <div class="flex items-center gap-3">
                    <span class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">🍽️</span>
                    <span>第一食堂</span>
                  </div>
                  <span class="font-medium">- ¥ 15.50</span>
                </div>
                <div class="flex items-center justify-between py-2 text-sm">
                  <div class="flex items-center gap-3">
                    <span class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center">📚</span>
                    <span>图书馆打印</span>
                  </div>
                  <span class="font-medium">- ¥ 2.00</span>
                </div>
                <div class="flex items-center justify-between py-2 text-sm">
                  <div class="flex items-center gap-3">
                    <span class="w-8 h-8 bg-orange-100 rounded-lg flex items-center justify-center">🏪</span>
                    <span>校园超市</span>
                  </div>
                  <span class="font-medium">- ¥ 23.80</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
