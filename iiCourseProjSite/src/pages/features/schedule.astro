---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import ScheduleTable from '../../components/schedule/ScheduleTable.vue';
---

<Layout title="课程表演示" description="查看课程表功能演示">
  <Navigation />
  
  <main class="pt-24 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 面包屑 -->
      <div class="breadcrumbs text-sm mb-8">
        <ul>
          <li><a href="/" class="hover:text-primary">首页</a></li>
          <li><a href="/features" class="hover:text-primary">功能</a></li>
          <li class="text-base-content">课程表</li>
        </ul>
      </div>
      
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-base-content mb-4">📅 课程表</h1>
        <p class="text-lg text-base-content/70">
          查看本周课程安排，支持按周次切换。不同课程使用不同颜色区分，一目了然。
        </p>
      </div>
      
      <!-- 功能亮点 -->
      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <div class="card bg-orange-50 border border-orange-200">
          <div class="card-body">
            <div class="text-2xl mb-2">🎨</div>
            <h3 class="card-title text-base">颜色区分</h3>
            <p class="text-sm text-base-content/70">不同课程不同颜色，快速识别</p>
          </div>
        </div>
        <div class="card bg-blue-50 border border-blue-200">
          <div class="card-body">
            <div class="text-2xl mb-2">📆</div>
            <h3 class="card-title text-base">周次切换</h3>
            <p class="text-sm text-base-content/70">支持 1-20 周自由切换</p>
          </div>
        </div>
        <div class="card bg-green-50 border border-green-200">
          <div class="card-body">
            <div class="text-2xl mb-2">ℹ️</div>
            <h3 class="card-title text-base">详细信息</h3>
            <p class="text-sm text-base-content/70">显示教室、教师等完整信息</p>
          </div>
        </div>
      </div>
      
      <!-- 课程表组件 -->
      <ScheduleTable client:load />
    </div>
  </main>
  
  <Footer />
</Layout>
