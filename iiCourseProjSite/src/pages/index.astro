---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import FeatureCard from '../components/FeatureCard.astro';

const features = [
  { icon: '📅', title: '课程表查询', description: '查看本周课表，支持多周切换，课程信息一目了然', color: 'bg-orange-100' },
  { icon: '📊', title: '成绩查询', description: '快速查询各科成绩，自动计算 GPA，学年筛选', color: 'bg-blue-100' },
  { icon: '🏫', title: '空教室查询', description: '查找空闲教室，自习好去处，按教学楼筛选', color: 'bg-green-100' },
  { icon: '💳', title: '一卡通余额', description: '实时查询一卡通余额和消费记录', color: 'bg-purple-100' },
  { icon: '⭐', title: '一键评教', description: '快速完成学生评教，告别繁琐操作', color: 'bg-yellow-100' },
  { icon: '🔐', title: 'CAS 登录', description: '支持智慧山商统一认证，安全便捷', color: 'bg-red-100' },
];
---

<Layout title="首页" description="iiCourse - 智慧校园桌面应用，课表成绩一手掌握">
  <Navigation />
  
  <main class="relative z-10">
    <HeroSection />
    
    <!-- 功能展示 -->
    <section class="py-24 relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="badge badge-glass mb-4">核心功能</span>
          <h2 class="section-title mb-4">
            功能齐全，<span class="gradient-text-warm">简单好用</span>
          </h2>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            六大核心功能，覆盖教务管理方方面面
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {features.map(feature => (
            <FeatureCard {...feature} />
          ))}
        </div>
      </div>
    </section>
    
    <!-- 统计数据展示（开发中） -->
    <section class="py-20 relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="glass-panel p-8 md:p-12 relative overflow-hidden">
          <!-- 开发中遮罩 -->
          <div class="absolute inset-0 bg-gray-100/80 backdrop-blur-sm flex items-center justify-center z-10">
            <div class="text-center">
              <div class="text-5xl mb-4">📊</div>
              <h3 class="text-2xl font-bold text-gray-800 mb-2">数据统计功能</h3>
              <p class="text-gray-600">正在开发中，敬请期待</p>
            </div>
          </div>
          <!-- 原始内容（置灰显示） -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-8 opacity-30 blur-sm">
            <div class="text-center">
              <div class="text-4xl md:text-5xl font-bold gradient-text-warm mb-2">1000+</div>
              <div class="text-gray-600">活跃用户</div>
            </div>
            <div class="text-center">
              <div class="text-4xl md:text-5xl font-bold gradient-text-warm mb-2">6</div>
              <div class="text-gray-600">核心功能</div>
            </div>
            <div class="text-center">
              <div class="text-4xl md:text-5xl font-bold gradient-text-warm mb-2">99%</div>
              <div class="text-gray-600">好评率</div>
            </div>
            <div class="text-center">
              <div class="text-4xl md:text-5xl font-bold gradient-text-warm mb-2">0</div>
              <div class="text-gray-600">隐私泄露</div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- CTA 区域 -->
    <section class="py-24 relative overflow-hidden">
      <!-- 背景渐变 -->
      <div class="absolute inset-0 bg-gradient-to-br from-orange-400/20 via-pink-400/15 to-purple-400/20"></div>
      
      <div class="relative max-w-4xl mx-auto px-4 text-center">
        <div class="glass-panel p-8 md:p-12">
          <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
            准备好体验了吗？
          </h2>
          <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
            完全免费，开源透明，立即下载开始使用
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/download" class="btn btn-primary btn-lg w-full sm:w-auto gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              立即下载 v1.7.200
            </a>
            <a href="https://github.com/iicemeta/iiCourseWPF" target="_blank" class="btn btn-glass btn-lg w-full sm:w-auto gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              查看源码
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
