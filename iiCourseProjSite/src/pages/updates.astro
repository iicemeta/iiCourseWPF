---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const changelog = [
  {
    version: '1.7.200',
    date: '2026-03-11',
    tag: '最新版本',
    tagColor: 'badge-success',
    features: [
      { icon: '🔐', title: 'CAS 登录', desc: '支持智慧山商统一认证' },
      { icon: '👤', title: '用户信息', desc: '查询个人资料和校园卡信息' },
      { icon: '📊', title: '成绩查询', desc: '查看各科成绩和 GPA' },
      { icon: '📅', title: '课表查看', desc: '查看完整课程安排' },
      { icon: '🏫', title: '空教室', desc: '查找空闲自习教室' },
      { icon: '💳', title: '一卡通', desc: '查询余额和消费记录' },
      { icon: '⭐', title: '一键评教', desc: '快速完成学生评教' },
      { icon: '⚙️', title: '设置页面', desc: '应用配置和个性化' },
    ]
  }
];

const roadmap = [
  { title: '考试安排查询', status: 'planned' },
  { title: '成绩趋势图表', status: 'planned' },
  { title: '课表导出功能', status: 'planned' },
  { title: '成绩更新提醒', status: 'planned' },
  { title: '深色模式', status: 'planned' },
  { title: '多语言支持', status: 'planned' },
];
---

<Layout title="更新日志" description="iiCourse 版本更新记录">
  <Navigation />
  
  <main class="pt-32 pb-16 relative z-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 页面标题 -->
      <div class="text-center mb-16">
        <span class="badge badge-glass mb-4">版本记录</span>
        <h1 class="section-title mb-4">
          更新<span class="gradient-text-warm">日志</span>
        </h1>
        <p class="text-xl text-gray-600">
          记录 iiCourse 的每一次成长
        </p>
      </div>
      
      <!-- 版本时间线 -->
      <div class="space-y-12">
        {changelog.map((release) => (
          <div class="relative">
            <!-- 版本标题 -->
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 bg-gradient-to-br from-orange-400 to-pink-400 rounded-2xl flex items-center justify-center text-white text-2xl font-bold shadow-lg">
                v
              </div>
              <div>
                <div class="flex items-center gap-3">
                  <h2 class="text-2xl font-bold text-gray-900">{release.version}</h2>
                  <span class={`badge ${release.tagColor}`}>
                    {release.tag}
                  </span>
                </div>
                <p class="text-gray-500 flex items-center gap-1 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
                  {release.date}
                </p>
              </div>
            </div>
            
            <!-- 功能列表 -->
            <div class="glass-panel">
              <div class="p-8">
                <h3 class="text-lg font-bold text-gray-900 mb-6 flex items-center gap-2">
                  <span class="w-8 h-8 rounded-lg bg-orange-100 text-orange-500 flex items-center justify-center text-sm">
                    ✨
                  </span>
                  新增功能
                </h3>
                <div class="grid md:grid-cols-2 gap-6">
                  {release.features.map((feature) => (
                    <div class="flex items-start gap-4 p-4 rounded-xl hover:bg-orange-50/50 transition-colors">
                      <div class="w-12 h-12 glass rounded-xl flex items-center justify-center text-2xl flex-shrink-0">
                        {feature.icon}
                      </div>
                      <div>
                        <h4 class="font-bold text-gray-900">{feature.title}</h4>
                        <p class="text-sm text-gray-600">{feature.desc}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <!-- 开发路线图 -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">开发路线图</h2>
        <div class="glass-panel">
          <div class="p-8">
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
              {roadmap.map((item) => (
                <div class="flex items-center gap-3 p-4 glass rounded-xl hover:shadow-md transition-shadow">
                  <div class="w-3 h-3 rounded-full bg-orange-300"></div>
                  <span class="text-gray-700 font-medium">{item.title}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
      
      <!-- 底部 CTA -->
      <div class="mt-12 text-center">
        <div class="glass-panel inline-block p-6">
          <p class="text-gray-600 mb-4">想要获取最新版本？</p>
          <a href="/download" class="btn btn-primary gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            立即下载
          </a>
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
