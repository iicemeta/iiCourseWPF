---
export interface Props {
  icon: string;
  title: string;
  description: string;
  color: string;
}

const { icon, title, description, color } = Astro.props;
---

<div class="group card hover:-translate-y-2">
  <div class={`w-14 h-14 ${color} rounded-2xl flex items-center justify-center text-3xl mb-4 
              group-hover:scale-110 transition-transform duration-300`}>
    {icon}
  </div>
  <h3 class="text-xl font-bold text-gray-900 mb-2">{title}</h3>
  <p class="text-gray-600 leading-relaxed">{description}</p>
</div>
