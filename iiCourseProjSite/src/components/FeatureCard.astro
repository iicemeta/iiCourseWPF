---
export interface Props {
  icon: string;
  title: string;
  description: string;
  color: string;
}

const { icon, title, description, color } = Astro.props;
---

<div class="card bg-base-100 shadow-xl hover:-translate-y-2 transition-transform duration-300 group">
  <div class="card-body">
    <div class={`w-14 h-14 ${color} rounded-2xl flex items-center justify-center text-3xl mb-4 
                group-hover:scale-110 transition-transform duration-300`}>
      {icon}
    </div>
    <h3 class="card-title text-xl">{title}</h3>
    <p class="text-base-content/70 leading-relaxed">{description}</p>
  </div>
</div>
