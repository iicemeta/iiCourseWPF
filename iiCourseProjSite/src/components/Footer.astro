---
import { footerConfig } from '../config/footer.config';

const { brand, columns, copyright } = footerConfig;
---

<footer class="relative mt-auto">
  <!-- 玻璃拟态背景 -->
  <div class="glass-light border-t border-white/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
        <!-- 品牌区域 -->
        <div class="lg:col-span-2">
          <a href="/" class="flex items-center gap-3 mb-6 group">
            <div class="relative">
              <img src="/iiCourse.png" alt="iiCourse" class="w-12 h-12 rounded-xl shadow-lg group-hover:scale-105 transition-transform" />
            </div>
            <div>
              <span class="font-bold text-2xl text-gray-900 block">{brand.name}</span>
              <span class="text-sm text-gray-500">智慧校园，一手掌握</span>
            </div>
          </a>
          <p class="text-gray-600 max-w-sm leading-relaxed mb-6">
            {brand.tagline}
          </p>
          
          <!-- 社交链接 -->
          <div class="flex items-center gap-3">
            <!-- GitHub -->
            <a href="https://github.com/iicemeta/iiCourseWPF" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-xl glass flex items-center justify-center text-gray-600 hover:text-orange-500 hover:scale-110 transition-all" title="GitHub">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
            <!-- Telegram 频道 -->
            <a href="https://t.me/iicourse" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-xl glass flex items-center justify-center text-gray-600 hover:text-orange-500 hover:scale-110 transition-all" title="Telegram 频道">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
            </a>
            <!-- Telegram 群组 -->
            <a href="https://t.me/iicoursecom" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-xl glass flex items-center justify-center text-gray-600 hover:text-orange-500 hover:scale-110 transition-all" title="Telegram 群组">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- 链接列 -->
        {columns.map((column) => (
          <div>
            <h4 class="font-bold text-gray-900 mb-5 text-lg">{column.title}</h4>
            <ul class="space-y-3">
              {column.links.map((link) => (
                <li>
                  <a href={link.href} class="text-gray-600 hover:text-orange-500 transition-colors flex items-center gap-2 group">
                    <span class="w-1.5 h-1.5 rounded-full bg-orange-300 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- 版权信息 -->
      <div class="mt-12 pt-8 border-t border-gray-200/50">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-gray-500 text-sm text-center md:text-left">
            {copyright}
          </p>
          <div class="flex items-center gap-6 text-sm text-gray-500">
            <a href="#" class="hover:text-orange-500 transition-colors">隐私政策</a>
            <a href="#" class="hover:text-orange-500 transition-colors">使用条款</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
