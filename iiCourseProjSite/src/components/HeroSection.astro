---
---

<section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
  <!-- 额外的装饰光晕 -->
  <div class="absolute top-1/4 right-0 w-96 h-96 bg-gradient-to-br from-orange-400/20 to-pink-400/20 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-1/4 w-80 h-80 bg-gradient-to-tr from-teal-400/15 to-cyan-400/15 rounded-full blur-3xl pointer-events-none"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- 左侧文案 -->
      <div class="space-y-8 relative z-10">
        <!-- 版本标签 -->
        <div class="inline-flex">
          <span class="badge badge-primary badge-lg gap-2 glass-shine">
            <span class="w-2 h-2 bg-white rounded-full animate-pulse"></span>
            v1.7.200 现已发布
          </span>
        </div>
        
        <!-- 主标题 -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold leading-tight text-shadow">
          <span class="text-gray-900">智慧校园</span>
          <br />
          <span class="gradient-text-warm">一手掌握</span>
        </h1>
        
        <!-- 描述 -->
        <p class="text-xl text-gray-600 max-w-lg leading-relaxed">
          课表、成绩、空教室查询，一键评教...<br/>
          告别繁琐操作，让教务管理变得轻松。
        </p>
        
        <!-- 按钮组 -->
        <div class="flex flex-wrap gap-4">
          <a href="/download" class="btn btn-primary btn-lg gap-2 group">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-y-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            免费下载
          </a>
          <a href="/features" class="btn btn-secondary btn-lg">
            了解更多
          </a>
        </div>
        
        <!-- 特性标签 -->
        <div class="flex items-center gap-6 text-sm">
          <div class="flex items-center gap-2 tag">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span class="text-gray-700">开源免费</span>
          </div>
          <div class="flex items-center gap-2 tag">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span class="text-gray-700">本地运行</span>
          </div>
          <div class="flex items-center gap-2 tag">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span class="text-gray-700">安全可靠</span>
          </div>
        </div>
      </div>
      
      <!-- 右侧应用展示 -->
      <div class="relative lg:pl-8">
        <!-- 主应用窗口 -->
        <div class="relative animate-float">
          <div class="glass-strong rounded-3xl p-4 shadow-2xl">
            <!-- 窗口标题栏 -->
            <div class="flex items-center gap-2 mb-4 px-2">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
              <div class="flex-1 text-center text-xs text-gray-400">iiCourse</div>
            </div>
            
            <!-- 应用内容 -->
            <div class="bg-gradient-to-br from-orange-50/80 to-white/80 rounded-2xl p-6 border border-white/60">
              <!-- 用户信息卡片 -->
              <div class="flex items-center gap-4 mb-6">
                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-orange-400 to-pink-400 flex items-center justify-center shadow-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                  </svg>
                </div>
                <div>
                  <div class="font-bold text-gray-900 text-lg">小涵</div>
                  <div class="text-gray-500 text-sm">艺术传媒学院 · 2023级</div>
                </div>
              </div>
              
              <!-- 数据卡片网格 -->
              <div class="grid grid-cols-2 gap-3">
                <div class="glass rounded-xl p-4">
                  <div class="text-gray-400 text-xs mb-1">余额</div>
                  <div class="font-bold text-gray-900 text-xl">¥ 128.50</div>
                </div>
                <div class="glass rounded-xl p-4">
                  <div class="text-gray-400 text-xs mb-1">绩点</div>
                  <div class="font-bold text-gray-900 text-xl">3.85</div>
                </div>
              </div>
              
              <!-- 快捷功能 -->
              <div class="mt-4 flex gap-2">
                <div class="flex-1 glass rounded-lg p-3 text-center">
                  <div class="text-2xl mb-1">📅</div>
                  <div class="text-xs text-gray-600">课表</div>
                </div>
                <div class="flex-1 glass rounded-lg p-3 text-center">
                  <div class="text-2xl mb-1">📊</div>
                  <div class="text-xs text-gray-600">成绩</div>
                </div>
                <div class="flex-1 glass rounded-lg p-3 text-center">
                  <div class="text-2xl mb-1">🏫</div>
                  <div class="text-xs text-gray-600">教室</div>
                </div>
                <div class="flex-1 glass rounded-lg p-3 text-center">
                  <div class="text-2xl mb-1">⭐</div>
                  <div class="text-xs text-gray-600">评教</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- 浮动装饰卡片 -->
        <div class="absolute -top-8 -right-8 glass rounded-2xl p-4 animate-float-delayed shadow-xl">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-400 to-teal-400 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <div>
              <div class="text-xs text-gray-500">评教完成</div>
              <div class="font-bold text-gray-900">+5 学分</div>
            </div>
          </div>
        </div>
        
        <!-- 另一个浮动卡片 -->
        <div class="absolute -bottom-4 -left-8 glass rounded-2xl p-4 animate-float shadow-xl">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-400 to-indigo-400 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <div>
              <div class="text-xs text-gray-500">下节课</div>
              <div class="font-bold text-gray-900">14:00 高数</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
