---
---

<section class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <!-- 背景装饰 -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-primary/20 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 -left-20 w-72 h-72 bg-secondary/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-1/4 w-64 h-64 bg-accent/10 rounded-full blur-3xl"></div>
  </div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- 左侧文案 -->
      <div class="space-y-8">
        <div class="badge badge-primary badge-lg gap-2">
          <span class="w-2 h-2 bg-white rounded-full animate-pulse"></span>
          v1.7.200 现已发布
        </div>
        
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tight">
          <span class="text-base-content">智慧校园</span>
          <br />
          <span class="gradient-text">一手掌握</span>
        </h1>
        
        <p class="text-xl text-base-content/70 max-w-lg leading-relaxed">
          课表、成绩、空教室查询，一键评教...<br/>
          告别繁琐操作，让教务管理变得轻松。
        </p>
        
        <div class="flex flex-wrap gap-4">
          <a href="/download" class="btn btn-primary btn-lg">
            免费下载
          </a>
          <a href="/features" class="btn btn-outline btn-lg border-primary text-primary hover:bg-primary hover:text-white">
            了解更多
          </a>
        </div>
        
        <div class="flex items-center gap-6 text-sm text-base-content/60">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            开源免费
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            本地运行
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            安全可靠
          </div>
        </div>
      </div>
      
      <!-- 右侧应用截图 -->
      <div class="relative">
        <div class="relative animate-float">
          <div class="card bg-base-100 shadow-2xl p-4 transform rotate-2 hover:rotate-0 transition-transform duration-500 border border-base-300">
            <div class="bg-base-200 rounded-xl overflow-hidden border border-base-300">
              <!-- 模拟应用界面 -->
              <div class="h-8 bg-base-300 flex items-center px-4 gap-2">
                <div class="w-3 h-3 rounded-full bg-error"></div>
                <div class="w-3 h-3 rounded-full bg-warning"></div>
                <div class="w-3 h-3 rounded-full bg-success"></div>
              </div>
              <div class="p-6 space-y-4">
                <div class="flex items-center gap-4">
                  <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                      <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                  </div>
                  <div>
                    <div class="text-base-content font-semibold">小涵</div>
                    <div class="text-base-content/50 text-sm">艺术传媒学院 · 2023级</div>
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-3">
                  <div class="bg-base-100 rounded-lg p-3 border border-base-300">
                    <div class="text-base-content/50 text-xs">余额</div>
                    <div class="text-base-content font-bold">¥ 128.50</div>
                  </div>
                  <div class="bg-base-100 rounded-lg p-3 border border-base-300">
                    <div class="text-base-content/50 text-xs">绩点</div>
                    <div class="text-base-content font-bold">3.85</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
