---
---

<section class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <!-- 背景装饰 -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-primary/20 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 -left-20 w-72 h-72 bg-secondary/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-1/4 w-64 h-64 bg-accent/10 rounded-full blur-3xl"></div>
  </div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- 左侧文案 -->
      <div class="space-y-8">
        <div class="inline-flex items-center px-4 py-2 bg-primary/10 text-primary rounded-full text-sm font-medium">
          <span class="w-2 h-2 bg-primary rounded-full mr-2 animate-pulse"></span>
          v1.7.200 现已发布
        </div>
        
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tight">
          <span class="text-gray-900">智慧校园</span>
          <br />
          <span class="gradient-text">一手掌握</span>
        </h1>
        
        <p class="text-xl text-gray-600 max-w-lg leading-relaxed">
          课表、成绩、空教室查询，一键评教...<br/>
          告别繁琐操作，让教务管理变得轻松。
        </p>
        
        <div class="flex flex-wrap gap-4">
          <a href="/download" class="btn-primary text-lg px-8 py-4">
            免费下载
          </a>
          <a href="/features" class="btn-secondary text-lg px-8 py-4">
            了解更多
          </a>
        </div>
        
        <div class="flex items-center space-x-6 text-sm text-gray-500">
          <div class="flex items-center">
            <span class="w-5 h-5 text-accent mr-2">✓</span>
            开源免费
          </div>
          <div class="flex items-center">
            <span class="w-5 h-5 text-accent mr-2">✓</span>
            本地运行
          </div>
          <div class="flex items-center">
            <span class="w-5 h-5 text-accent mr-2">✓</span>
            安全可靠
          </div>
        </div>
      </div>
      
      <!-- 右侧应用截图 -->
      <div class="relative">
        <div class="relative animate-float">
          <div class="bg-gray-900 rounded-2xl shadow-2xl p-4 transform rotate-2 hover:rotate-0 transition-transform duration-500">
            <div class="bg-gray-800 rounded-xl overflow-hidden">
              <!-- 模拟应用界面 -->
              <div class="h-8 bg-gray-700 flex items-center px-4 space-x-2">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
              </div>
              <div class="p-6 space-y-4">
                <div class="flex items-center space-x-4">
                  <div class="w-16 h-16 bg-primary/20 rounded-full flex items-center justify-center">
                    <span class="text-2xl">👤</span>
                  </div>
                  <div>
                    <div class="text-white font-semibold">小涵</div>
                    <div class="text-gray-400 text-sm">艺术传媒学院 · 2023级</div>
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-3">
                  <div class="bg-gray-700/50 rounded-lg p-3">
                    <div class="text-gray-400 text-xs">余额</div>
                    <div class="text-white font-bold">¥ 128.50</div>
                  </div>
                  <div class="bg-gray-700/50 rounded-lg p-3">
                    <div class="text-gray-400 text-xs">绩点</div>
                    <div class="text-white font-bold">3.85</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
