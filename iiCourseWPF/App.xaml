<Application x:Class="iiCourseWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:iiCourseWPF"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Animations.xaml"/>
                <ResourceDictionary Source="Resources/ScrollBarStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        <!-- 全局颜色资源 - 温暖活泼配色方案 -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#FF6B35"/>
        <SolidColorBrush x:Key="PrimaryHoverColor" Color="#FF8555"/>
        <SolidColorBrush x:Key="PrimaryPressedColor" Color="#E55A25"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#FFD23F"/>
        <SolidColorBrush x:Key="AccentColor" Color="#4ECDC4"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#FFF8F0"/>
        <SolidColorBrush x:Key="SidebarBackgroundColor" Color="#FAFAFA"/>
        <SolidColorBrush x:Key="SidebarActiveColor" Color="#FF6B35"/>
        <SolidColorBrush x:Key="TextColor" Color="#2C3E50"/>
        <SolidColorBrush x:Key="SecondaryTextColor" Color="#7F8C8D"/>
        <SolidColorBrush x:Key="CardBackgroundColor" Color="White"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#27AE60"/>
        <SolidColorBrush x:Key="WarningColor" Color="#F39C12"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#E74C3C"/>
        <SolidColorBrush x:Key="BorderColor" Color="#FFE8D6"/>
        <SolidColorBrush x:Key="HoverBackgroundColor" Color="#FFF5EB"/>

        <!-- 全局字体设置 -->
        <FontFamily x:Key="PrimaryFontFamily">Microsoft YaHei UI, SimHei, Arial</FontFamily>

        <Style TargetType="Control">
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}"/>
        </Style>

        <!-- 按钮全局样式 -->
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- 文本框全局样式 -->
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 密码框全局样式 -->
        <Style TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

