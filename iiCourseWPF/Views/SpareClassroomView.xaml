<UserControl x:Class="iiCourseWPF.Views.SpareClassroomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- 课时标签样式 -->
        <Style x:Key="PeriodTagStyle" TargetType="Border">
            <Setter Property="Background" Value="#E8F5E9"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
        
        <!-- 课时行样式 -->
        <Style x:Key="PeriodRowStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FF6B35" Opacity="0.04" BlurRadius="8" ShadowDepth="1"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundColor}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- 头部标题 -->
                <Border Style="{StaticResource PageHeaderStyle}">
                    <StackPanel>
                        <TextBlock Text="空教室查询" FontSize="24" FontWeight="Bold" 
                                  Foreground="White" Margin="0,0,0,6"/>
                        <TextBlock Text="按课时查找空闲教室" FontSize="13" 
                                  Foreground="#D9FFFFFF"/>
                    </StackPanel>
                </Border>

                <!-- 查询控制区 -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="20,20,20,10">
                    <StackPanel>
                        <!-- 校区选择 -->
                        <TextBlock Text="选择校区" FontSize="13" FontWeight="SemiBold" 
                                  Foreground="#2C3E50" Margin="0,0,0,10"/>
                        
                        <WrapPanel x:Name="CampusButtonsPanel" Orientation="Horizontal" Margin="0,0,0,14">
                            <!-- 校区按钮将在这里动态生成 -->
                        </WrapPanel>

                        <!-- 教学楼选择 -->
                        <TextBlock Text="选择教学楼" FontSize="13" FontWeight="SemiBold" 
                                  Foreground="#2C3E50" Margin="0,0,0,10"/>

                        <WrapPanel x:Name="BuildingButtonsPanel" Orientation="Horizontal">
                            <!-- 教学楼按钮将在这里动态生成 -->
                        </WrapPanel>

                        <TextBlock x:Name="StatusText" Text="" 
                                  FontSize="12" Foreground="#7F8C8D" 
                                  Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 课时筛选区 -->
                <Border x:Name="PeriodFilterPanel" Style="{StaticResource CardBorderStyle}" 
                        Margin="20,10,20,10" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="快速筛选：你什么时候有空？" 
                                  FontSize="13" FontWeight="SemiBold" 
                                  Foreground="#2C3E50" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Text="点击你空闲的课时，查看该时段所有空教室" 
                                  FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,10"/>
                        
                        <!-- 使用WrapPanel实现响应式布局 -->
                        <WrapPanel x:Name="PeriodFilterButtons" Grid.Row="2" Orientation="Horizontal">
                            <!-- 课时筛选按钮动态生成 -->
                        </WrapPanel>
                    </Grid>
                </Border>

                <!-- 空教室列表 - 按课时分组 -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="20,10,20,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="空闲教室列表" FontSize="15" FontWeight="SemiBold" 
                                      Foreground="#2C3E50" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ResultCountText" Grid.Column="1" Text="" 
                                      FontSize="12" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel x:Name="ClassroomByPeriodPanel">
                            <!-- 按课时分组的内容将在这里动态生成 -->
                            <Border Style="{StaticResource PeriodRowStyle}" Background="{StaticResource LightBackgroundColor}">
                                <StackPanel>
                                    <Path Width="32" Height="32" Data="{StaticResource RoomIcon}"
                                          Fill="#7F8C8D" Stretch="Uniform" Margin="0,0,0,10"
                                          HorizontalAlignment="Center"/>
                                    <TextBlock Text="请选择教学楼查询"
                                              FontSize="12" Foreground="#7F8C8D"
                                              TextAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>