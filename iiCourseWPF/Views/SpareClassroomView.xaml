<UserControl x:Class="iiCourseWPF.Views.SpareClassroomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:iiCourseWPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- 课时标签样式 -->
        <Style x:Key="PeriodTagStyle" TargetType="Border">
            <Setter Property="Background" Value="#E8F5E9"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
        
        <!-- 课时行样式 -->
        <Style x:Key="PeriodRowStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FF6B35" Opacity="0.04" BlurRadius="8" ShadowDepth="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 校区/教学楼按钮样式 -->
        <Style x:Key="OptionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{Binding BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{Binding ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="{TemplateBinding Margin}">
                            <!-- 外发光层 - 选中时显示 -->
                            <Border x:Name="GlowBorder"
                                    Background="Transparent"
                                    CornerRadius="10"
                                    Opacity="0"
                                    Margin="-4"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF6B35" 
                                                      Opacity="0.6" 
                                                      BlurRadius="16" 
                                                      ShadowDepth="0"/>
                            </Border.Effect>
                            <Border Background="#FF6B35" CornerRadius="10"/>
                            </Border>
                            <!-- 主按钮 -->
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5"
                                    BorderBrush="{x:Null}"
                                    BorderThickness="0">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <ContentPresenter HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"
                                                TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="GlowBorder" Property="Opacity" Value="1"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF8555"/>
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E55A25"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 节次筛选按钮样式 -->
        <Style x:Key="PeriodFilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{Binding BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{Binding ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="{TemplateBinding Margin}">
                            <!-- 外发光层 - 选中时显示 -->
                            <Border x:Name="GlowBorder"
                                    Background="Transparent"
                                    CornerRadius="8"
                                    Opacity="0"
                                    Margin="-3"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF6B35" 
                                                      Opacity="0.55" 
                                                      BlurRadius="14" 
                                                      ShadowDepth="0"/>
                                </Border.Effect>
                                <Border Background="#FF6B35" CornerRadius="8"/>
                            </Border>
                            <!-- 主按钮 -->
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5"
                                    BorderBrush="{x:Null}"
                                    BorderThickness="0">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <ContentPresenter HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"
                                                TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="GlowBorder" Property="Opacity" Value="1"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF8555"/>
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.93" ScaleY="0.93"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E55A25"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 教室卡片样式 -->
        <Style x:Key="ClassroomCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundColor}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- 头部标题 -->
                <Border Style="{StaticResource PageHeaderStyle}">
                    <StackPanel>
                        <TextBlock Text="空教室查询" FontSize="24" FontWeight="Bold" 
                                  Foreground="White" Margin="0,0,0,6"/>
                        <TextBlock Text="按课时查找空闲教室" FontSize="13" 
                                  Foreground="#D9FFFFFF"/>
                    </StackPanel>
                </Border>

                <!-- 查询控制区 -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="20,20,20,10">
                    <StackPanel>
                        <!-- 提示信息 -->
                        <Border Background="#FFF3E0" CornerRadius="6" Padding="12,10" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="16" Height="16" Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,17A1,1 0 0,1 11,16A1,1 0 0,1 12,15A1,1 0 0,1 13,16A1,1 0 0,1 12,17M13,12.5V13H11V11H12.5A1.5,1.5 0 0,0 11,9.5A1.5,1.5 0 0,0 9.5,11H8A3.5,3.5 0 0,1 12,7.5A3.5,3.5 0 0,1 15.5,11A3.5,3.5 0 0,1 13,12.5Z"
                                      Fill="#FF6B35" Stretch="Uniform" Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                                <TextBlock Text="当前仅支持查询当日空教室" FontSize="12" 
                                          Foreground="#E65100" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 校区选择 -->
                        <TextBlock Text="选择校区" FontSize="13" FontWeight="SemiBold" 
                                  Foreground="#2C3E50" Margin="0,0,0,10"/>
                        
                        <ItemsControl ItemsSource="{Binding CampusOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource OptionButtonStyle}"
                                            Command="{Binding DataContext.SelectCampusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Width="14" Height="14"
                                                  Data="{StaticResource SchoolIcon}"
                                                  Fill="{Binding ForegroundBrush}"
                                                  Stretch="Uniform"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" 
                                                      VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 教学楼选择 -->
                        <TextBlock Text="选择教学楼" FontSize="13" FontWeight="SemiBold" 
                                  Foreground="#2C3E50" Margin="0,14,0,10"/>

                        <ItemsControl ItemsSource="{Binding BuildingOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource OptionButtonStyle}"
                                            Command="{Binding DataContext.SelectBuildingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}"
                                            Content="{Binding Name}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding StatusMessage}" 
                                  FontSize="12" Foreground="#7F8C8D" 
                                  Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 课时筛选区 -->
                <Border Style="{StaticResource CardBorderStyle}" 
                        Margin="20,10,20,10"
                        Visibility="{Binding ShowPeriodFilter, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="快速筛选：你什么时候有空？" 
                                  FontSize="13" FontWeight="SemiBold" 
                                  Foreground="#2C3E50" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Text="点击你空闲的课时，查看该时段所有空教室" 
                                  FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,10"/>
                        
                        <!-- 节次筛选按钮 -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding PeriodFilterOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource PeriodFilterButtonStyle}"
                                            Command="{Binding DataContext.SelectPeriodCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Period}"
                                            Content="{Binding DisplayText}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- 空教室列表 - 按课时分组 -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="20,10,20,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="空闲教室列表" FontSize="15" FontWeight="SemiBold" 
                                      Foreground="#2C3E50" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" 
                                      Text="{Binding ResultCountText}"
                                      FontSize="12" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- 空教室分组列表 -->
                        <ItemsControl ItemsSource="{Binding FilteredPeriodGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- 每个节次分组 -->
                                    <Border Style="{StaticResource PeriodRowStyle}">
                                        <StackPanel>
                                            <!-- 节次标题 -->
                                            <Border Background="#E8F5E9"
                                                    CornerRadius="4"
                                                    Padding="6,3"
                                                    Margin="0,0,0,10"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding DisplayText}"
                                                          FontSize="12"
                                                          FontWeight="SemiBold"
                                                          Foreground="#2E7D32"/>
                                            </Border>

                                            <!-- 教室列表 -->
                                            <ItemsControl ItemsSource="{Binding Classrooms}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource ClassroomCardStyle}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Path Width="12" Height="12"
                                                                      Data="{StaticResource RoomIcon}"
                                                                      Fill="#FF6B35"
                                                                      Stretch="Uniform"
                                                                      Margin="0,0,6,0"
                                                                      VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding ClassroomName}"
                                                                          FontSize="11"
                                                                          Foreground="#2C3E50"
                                                                          VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- 无教室提示 -->
                                            <TextBlock Text="该时段无空教室"
                                                      FontSize="11"
                                                      Foreground="#7F8C8D"
                                                      Margin="0,5,0,0"
                                                      Visibility="{Binding Classrooms.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 空状态提示 -->
                        <Border Style="{StaticResource PeriodRowStyle}" 
                                Background="{StaticResource LightBackgroundColor}"
                                Visibility="{Binding HasData, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center">
                                <Path Width="32" Height="32" Data="{StaticResource RoomIcon}"
                                      Fill="#7F8C8D" Stretch="Uniform" Margin="0,0,0,10"
                                      HorizontalAlignment="Center"/>
                                <TextBlock Text="请选择教学楼查询"
                                          FontSize="12" Foreground="#7F8C8D"
                                          TextAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
