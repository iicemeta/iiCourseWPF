<UserControl x:Class="iiCourseWPF.Views.ScoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- 表头样式 -->
        <Style x:Key="HeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF6B35"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="6,6,0,0"/>
        </Style>

        <!-- 行样式 -->
        <Style x:Key="RowStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,10"/>
        </Style>

        <!-- 交替行样式 -->
        <Style x:Key="AlternateRowStyle" TargetType="Border" BasedOn="{StaticResource RowStyle}">
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>

        <!-- 下拉框样式 - 与课程表统一 -->
        <Style x:Key="ScoreComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE8D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- 主边框 -->
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 内容显示 -->
                                    <ContentPresenter x:Name="ContentSite"
                                                      Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                    <!-- 箭头图标 -->
                                    <Path x:Name="Arrow"
                                          Grid.Column="1"
                                          Data="M0,0 L4,4 L8,0"
                                          Stroke="#FF6B35"
                                          StrokeThickness="2"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            
                            <!-- 透明ToggleButton覆盖整个区域，点击任意位置触发下拉 -->
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            
                            <!-- 下拉框Popup -->
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{Binding ActualWidth, ElementName=Border}">
                                    <Border x:Name="DropDownBorder"
                                            Background="White"
                                            BorderBrush="#FFE8D6"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,4,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FF6B35" Opacity="0.15" BlurRadius="12" ShadowDepth="2"/>
                                        </Border.Effect>
                                        <ScrollViewer x:Name="DropDownScrollViewer"
                                                      MaxHeight="200"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsPresenter x:Name="ItemsPresenter"
                                                            KeyboardNavigation.DirectionalNavigation="Contained"
                                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FF6B35"/>
                                <Setter TargetName="Border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF6B35" Opacity="0.1" BlurRadius="8" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FF6B35"/>
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" CenterX="4" CenterY="2"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem样式 - 与课程表统一 -->
        <Style x:Key="ScoreComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" 
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFF5EB"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFE8D6"/>
                                <Setter Property="Foreground" Value="#FF6B35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundColor}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- 头部标题 -->
                <Border Style="{StaticResource PageHeaderStyle}">
                    <StackPanel>
                        <TextBlock Text="成绩查询" FontSize="24" FontWeight="Bold" 
                                  Foreground="White" Margin="0,0,0,6"/>
                        <TextBlock Text="查看您的考试成绩" FontSize="13" 
                                  Foreground="#D9FFFFFF"/>
                    </StackPanel>
                </Border>

                <!-- 自定义查询区域 -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="20,20,20,0">
                    <StackPanel>
                        <TextBlock Text="自定义查询" FontSize="14" FontWeight="SemiBold" 
                                  Foreground="#2C3E50" Margin="0,0,0,12"/>
                        
                        <StackPanel Orientation="Horizontal">
                            <!-- 学年选择 -->
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="学年" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <ComboBox x:Name="SchoolYearComboBox"
                                          Style="{StaticResource ScoreComboBoxStyle}"
                                          ItemContainerStyle="{StaticResource ScoreComboBoxItemStyle}"
                                          Width="140"
                                          ItemsSource="{Binding SchoolYears}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedSchoolYear}"/>
                            </StackPanel>

                            <!-- 学期选择 -->
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="学期" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <ComboBox x:Name="SemesterComboBox"
                                          Style="{StaticResource ScoreComboBoxStyle}"
                                          ItemContainerStyle="{StaticResource ScoreComboBoxItemStyle}"
                                          Width="100"
                                          SelectedValuePath="Tag"
                                          SelectedValue="{Binding SelectedSemester}">
                                    <ComboBoxItem Content="请选择" Tag="" Style="{StaticResource ScoreComboBoxItemStyle}"/>
                                    <ComboBoxItem Content="第一学期" Tag="1" Style="{StaticResource ScoreComboBoxItemStyle}"/>
                                    <ComboBoxItem Content="第二学期" Tag="2" Style="{StaticResource ScoreComboBoxItemStyle}"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- 查询按钮 -->
                            <Button Command="{Binding QueryCommand}"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="20,0" Height="36" Margin="0,18,0,0">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="14" Height="14" Data="{StaticResource SearchIcon}"
                                              Fill="White" Stretch="Uniform" Margin="0,0,6,0"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="查询" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 成绩列表 -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="20,16,20,0">
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 操作栏 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Command="{Binding RefreshCommand}"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="16,10" FontSize="13">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="14" Height="14" Data="{StaticResource RefreshIcon}"
                                              Fill="White" Stretch="Uniform" Margin="0,0,6,0"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="刷新成绩" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <TextBlock Text="{Binding StatusMessage}" 
                                      FontSize="13" Foreground="#7F8C8D" 
                                      VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>

                        <!-- 成绩表格 -->
                        <Border Grid.Row="1" BorderBrush="#E8E8E8" BorderThickness="1"
                                CornerRadius="8" Background="White">
                            <StackPanel x:Name="ScorePanel">
                                <!-- 表头 -->
                                <Border Style="{StaticResource HeaderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" MinWidth="120"/>
                                            <ColumnDefinition Width="*" MinWidth="50"/>
                                            <ColumnDefinition Width="*" MinWidth="50"/>
                                            <ColumnDefinition Width="*" MinWidth="50"/>
                                            <ColumnDefinition Width="*" MinWidth="60"/>
                                            <ColumnDefinition Width="*" MinWidth="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="课程名称" FontSize="11" FontWeight="SemiBold"
                                                  Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="学分" FontSize="11" FontWeight="SemiBold"
                                                  Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="成绩" FontSize="11" FontWeight="SemiBold"
                                                  Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="绩点" FontSize="11" FontWeight="SemiBold"
                                                  Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="性质" FontSize="11" FontWeight="SemiBold"
                                                  Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="学期" FontSize="11" FontWeight="SemiBold"
                                                  Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- 成绩数据将在这里动态生成 -->
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- 底部间距 -->
                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
