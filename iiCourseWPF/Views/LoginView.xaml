<UserControl x:Class="iiCourseWPF.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="400">
    <UserControl.Resources>
        <!-- 输入框容器样式 -->
        <Style x:Key="InputBoxStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FF6B35" Opacity="0" BlurRadius="10" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource InputFocusAnimation}"/>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard Storyboard="{StaticResource InputBlurAnimation}"/>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 图标样式 -->
        <Style x:Key="InputIconStyle" TargetType="Path">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Fill" Value="#7F8C8D"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 状态文本颜色转换器 -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="#FFF8F0">
        <!-- 装饰性背景 -->
        <Grid>
            <Ellipse Width="400" Height="400" Fill="#FF6B35" Opacity="0.05" 
                     Margin="-200,-100,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Ellipse Width="300" Height="300" Fill="#FFD23F" Opacity="0.05" 
                     Margin="0,0,-100,-50" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </Grid>

        <!-- 登录卡片 -->
        <Border Background="White" CornerRadius="16" 
                Margin="24,20" 
                MaxWidth="420" MinWidth="280"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#FF6B35" Opacity="0.12" BlurRadius="30" ShadowDepth="4"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="32,32">
                    <!-- 标题区域 -->
                    <StackPanel Margin="0,0,0,28">
                        <TextBlock Text="登录 iiCourse" FontSize="24" FontWeight="Bold"
                                  Foreground="#2C3E50" TextAlignment="Center"/>
                        <TextBlock Text="请输入您的学号和密码" FontSize="13" 
                                  Foreground="#7F8C8D" TextAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- 学号输入 -->
                    <StackPanel>
                        <TextBlock Text="学号" FontSize="12" FontWeight="SemiBold" 
                                  Foreground="#2C3E50" Margin="0,0,0,4"/>
                        <Border Style="{StaticResource InputBoxStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Style="{StaticResource InputIconStyle}" 
                                      Data="{StaticResource UserIcon}"/>
                                <TextBox Grid.Column="1" 
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" 
                                         FontSize="14" VerticalAlignment="Center" 
                                         VerticalContentAlignment="Center" Padding="0"
                                         Background="Transparent" CaretBrush="#FF6B35"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- 密码输入 -->
                    <StackPanel Margin="0,14,0,0">
                        <TextBlock Text="密码" FontSize="12" FontWeight="SemiBold" 
                                  Foreground="#2C3E50" Margin="0,0,0,4"/>
                        <Border Style="{StaticResource InputBoxStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Style="{StaticResource InputIconStyle}" 
                                      Data="{StaticResource LockIcon}"/>
                                <PasswordBox x:Name="PasswordBox"
                                            Grid.Column="1" 
                                            PasswordChanged="OnPasswordChanged"
                                            BorderThickness="0" 
                                            FontSize="14" VerticalAlignment="Center" 
                                            VerticalContentAlignment="Center" Padding="0"
                                            Background="Transparent" CaretBrush="#FF6B35"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- 记住密码选项 -->
                    <CheckBox IsChecked="{Binding RememberPassword}" 
                              Content="记住账号密码" 
                              FontSize="12" 
                              Foreground="#7F8C8D"
                              Margin="0,14,0,0"
                              VerticalContentAlignment="Center"
                              Cursor="Hand">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border x:Name="CheckBorder" 
                                                        Width="20" Height="20" 
                                                        CornerRadius="6"
                                                        Background="White"
                                                        BorderBrush="#E0E0E0"
                                                        BorderThickness="2"
                                                        Margin="0,0,10,0">

                                                    <Grid>
                                                        <!-- 勾选图标 -->
                                                        <Path x:Name="CheckMark" 
                                                              Data="{StaticResource CheckIcon}"
                                                              Width="12" Height="12"
                                                              Stretch="Uniform"
                                                              Fill="White"
                                                              HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"
                                                              Opacity="0"
                                                              RenderTransformOrigin="0.5,0.5">
                                                            <Path.RenderTransform>
                                                                <ScaleTransform x:Name="CheckScale" ScaleX="0" ScaleY="0"/>
                                                            </Path.RenderTransform>
                                                        </Path>
                                                        <!-- 锁定图标（记住密码时显示） -->
                                                        <Path x:Name="LockSmallIcon" 
                                                              Data="{StaticResource LockIcon}"
                                                              Width="10" Height="10"
                                                              Stretch="Uniform"
                                                              Fill="White"
                                                              HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"
                                                              Opacity="0"
                                                              RenderTransformOrigin="0.5,0.5">
                                                            <Path.RenderTransform>
                                                                <ScaleTransform x:Name="LockScale" ScaleX="0" ScaleY="0"/>
                                                            </Path.RenderTransform>
                                                        </Path>
                                                    </Grid>
                                                </Border>
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <!-- 选中状态 -->
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CheckBorder" Property="Background" Value="#FF6B35"/>
                                                    <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#FF6B35"/>
                                                    <Setter TargetName="CheckMark" Property="Opacity" Value="1"/>
                                                    <!-- 勾选动画 -->
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="CheckScale"
                                                                                 Storyboard.TargetProperty="ScaleX"
                                                                                 From="0" To="1.2" Duration="0:0:0.15"/>
                                                                <DoubleAnimation Storyboard.TargetName="CheckScale"
                                                                                 Storyboard.TargetProperty="ScaleY"
                                                                                 From="0" To="1.2" Duration="0:0:0.15"/>
                                                                <DoubleAnimation Storyboard.TargetName="CheckScale"
                                                                                 Storyboard.TargetProperty="ScaleX"
                                                                                 From="1.2" To="1" Duration="0:0:0.1"
                                                                                 BeginTime="0:0:0.15"/>
                                                                <DoubleAnimation Storyboard.TargetName="CheckScale"
                                                                                 Storyboard.TargetProperty="ScaleY"
                                                                                 From="1.2" To="1" Duration="0:0:0.1"
                                                                                 BeginTime="0:0:0.15"/>

                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="CheckScale"
                                                                                 Storyboard.TargetProperty="ScaleX"
                                                                                 To="0" Duration="0:0:0.1"/>
                                                                <DoubleAnimation Storyboard.TargetName="CheckScale"
                                                                                 Storyboard.TargetProperty="ScaleY"
                                                                                 To="0" Duration="0:0:0.1"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                                <!-- 悬停状态 -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#FF6B35"/>
                                                    <Setter TargetName="CheckBorder" Property="Background" Value="#FFF5F0"/>
                                                    <Setter TargetName="CheckBorder" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#FF6B35" Opacity="0.3" BlurRadius="8" ShadowDepth="0"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <!-- 按下状态 -->
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="CheckBorder" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <!-- 登录按钮 -->
                    <Button Content="登录" 
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,24,0,0" HorizontalAlignment="Stretch"/>

                    <!-- 状态信息 -->
                    <TextBlock Text="{Binding StatusMessage}" 
                              FontSize="12" 
                              Foreground="{Binding IsStatusError, Converter={StaticResource BoolToColorConverter}, FallbackValue=#E74C3C}" 
                              TextAlignment="Center" 
                              TextWrapping="Wrap" 
                              Margin="0,12,0,0"
                              Visibility="{Binding IsStatusVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- 加载动画 -->
                    <StackPanel Orientation="Horizontal" 
                               HorizontalAlignment="Center" 
                               Margin="0,12,0,0" 
                               Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Path x:Name="LoadingPath" Width="16" Height="16" Data="{StaticResource RefreshIcon}"
                              Fill="#FF6B35" Stretch="Uniform" Margin="0,0,8,0"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform x:Name="LoadingRotate" Angle="0"/>
                            </Path.RenderTransform>
                            <Path.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="LoadingRotate"
                                                           Storyboard.TargetProperty="Angle"
                                                           From="0" To="360" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Path.Triggers>
                        </Path>
                        <TextBlock Text="登录中..." FontSize="12" Foreground="#FF6B35" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 提示信息 -->
                    <Border Background="#FFF8F0" CornerRadius="8" Margin="0,16,0,0" Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="16" Height="16" Data="{StaticResource LightbulbIcon}"
                                  Fill="#FF6B35" Stretch="Uniform" Margin="0,0,10,0"
                                  VerticalAlignment="Top"/>
                            <TextBlock Text="请使用学校统一身份认证账号登录" FontSize="12" 
                                      Foreground="#7F8C8D" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
