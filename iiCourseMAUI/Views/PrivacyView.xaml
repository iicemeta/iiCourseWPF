<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage x:Class="iiCourseMAUI.Views.PrivacyView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="隐私政策"
             BackgroundColor="{StaticResource BackgroundColor}">

    <ScrollView>
        <StackLayout Spacing="0">
            <Border Style="{StaticResource PageHeaderStyle}">
                <StackLayout Spacing="6">
                    <Label Text="隐私政策" FontSize="24" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="我们如何处理和保护您的数据" FontSize="13" TextColor="#D9FFFFFF"/>
                </StackLayout>
            </Border>

            <StackLayout Padding="16" Spacing="12">
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackLayout Orientation="Horizontal" Spacing="8">
                        <Label Text="{StaticResource IconClock}"
                               FontSize="14"
                               TextColor="{StaticResource SecondaryTextColor}"/>
                        <Label Text="最后更新时间：2025年3月9日" FontSize="12"
                               TextColor="{StaticResource SecondaryTextColor}"/>
                    </StackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackLayout Spacing="10">
                        <Label Text="简介" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}"/>
                        <Label FontSize="12" TextColor="#555555" LineBreakMode="WordWrap">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="iiCourse（以下简称"/>
                                    <Span Text="我们" FontAttributes="Bold"/>
                                    <Span Text="、"/>
                                    <Span Text="本应用" FontAttributes="Bold"/>
                                    <Span Text="）是一款面向山东工商学院学生的第三方教务助手应用。我们非常重视用户的隐私保护，本隐私政策将详细说明我们如何收集、使用、存储和保护您的个人信息。"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </StackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackLayout Spacing="12">
                        <Label Text="1. 我们收集的信息" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}"/>

                        <Label Text="1.1 账户信息" FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}"/>
                        <Label Text="当您使用本应用时，我们需要您提供以下信息以访问学校教务系统："
                               FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>

                        <StackLayout Margin="12,0,0,0">
                            <Label Text="学号：用于身份验证和登录教务系统"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                            <Label Text="密码：用于登录学校CAS认证系统（可选记住密码功能）"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                        </StackLayout>

                        <Label Text="1.2 教务系统数据" FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}" Margin="0,8,0,0"/>
                        <Label Text="在您登录后，应用会从学校教务系统获取以下信息用于展示："
                               FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>

                        <StackLayout Margin="12,0,0,0">
                            <Label Text="个人基本信息（姓名、性别、学院）" FontSize="12" TextColor="#555555"/>
                            <Label Text="课程表信息（课程名称、上课时间、地点、教师）" FontSize="12" TextColor="#555555"/>
                            <Label Text="考试成绩信息" FontSize="12" TextColor="#555555"/>
                            <Label Text="一卡通余额和消费记录" FontSize="12" TextColor="#555555"/>
                            <Label Text="评教任务信息" FontSize="12" TextColor="#555555"/>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackLayout Spacing="12">
                        <Label Text="2. 信息的使用方式" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}"/>

                        <Label Text="我们收集的信息仅用于以下目的："
                               FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>

                        <StackLayout Margin="12,0,0,0">
                            <Label Text="身份验证：使用您的学号和密码登录学校教务系统"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                            <Label Text="数据展示：从教务系统获取您的课程、成绩等信息并展示"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                            <Label Text="功能实现：提供空教室查询、评教等功能"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                            <Label Text="问题排查：通过日志分析解决应用故障"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                        </StackLayout>

                        <Border BackgroundColor="{StaticResource HoverBackgroundColor}"
                                StrokeShape="RoundRectangle 6"
                                Padding="12,10" Margin="0,8,0,0">
                            <Label FontSize="11" TextColor="{StaticResource PrimaryColor}"
                                   FontAttributes="Bold" LineBreakMode="WordWrap">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="重要声明："/>
                                        <Span Text="我们不会将您的任何信息用于上述目的之外的用途，不会向第三方出售或共享您的个人信息。"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </Border>
                    </StackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackLayout Spacing="12">
                        <Label Text="3. 信息的存储和保护" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}"/>

                        <Label Text="3.1 本地存储" FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}"/>
                        <Label Text="应用在本地存储以下信息："
                               FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>

                        <StackLayout Margin="12,0,0,0">
                            <Label Text="会话Cookie：存储在内存中，应用关闭后自动清除"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                            <Label Text="临时缓存：课程表、成绩等数据可能临时缓存在内存中"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                            <Label FontSize="12" TextColor="#555555" LineBreakMode="WordWrap">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="密码（可选）：如果您选择"/>
                                        <Span Text="记住密码" FontAttributes="Bold"/>
                                        <Span Text="，密码将使用"/>
                                        <Span Text="平台安全存储 API" FontAttributes="Bold"/>
                                        <Span Text="加密后存储在本地。"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </StackLayout>

                        <Label Text="3.2 数据传输安全" FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}" Margin="0,8,0,0"/>
                        <StackLayout Margin="12,0,0,0">
                            <Label Text="使用DES加密算法对敏感数据进行加密传输"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                            <Label Text="所有与学校系统的通信均使用HTTPS协议"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                            <Label Text="遵循学校CAS单点登录的安全规范"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackLayout Spacing="12">
                        <Label Text="4. 信息共享与披露" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}"/>

                        <Label FontSize="12" TextColor="#555555" LineBreakMode="WordWrap">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="我们"/>
                                    <Span Text="不会" FontAttributes="Bold" TextColor="{StaticResource ErrorColor}"/>
                                    <Span Text="将您的个人信息出售、交易或以其他方式转让给第三方。但在以下情况下，我们可能会披露您的信息："/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <StackLayout Margin="12,0,0,0">
                            <Label Text="法律要求：根据法律法规或政府机关的合法要求"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                            <Label Text="保护权益：为保护我们的合法权益或用户安全所必需"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                            <Label Text="学校要求：根据学校相关部门的正式要求"
                                   FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackLayout Spacing="12">
                        <Label Text="5. 您的权利" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}"/>

                        <Label Text="作为用户，您享有以下权利："
                               FontSize="12" TextColor="#555555" LineBreakMode="WordWrap"/>

                        <StackLayout Margin="12,0,0,0">
                            <Label FontSize="12" TextColor="#555555" LineBreakMode="WordWrap">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="访问权：" FontAttributes="Bold"/>
                                        <Span Text="您可以随时查看应用中展示的所有您的个人信息"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label FontSize="12" TextColor="#555555" LineBreakMode="WordWrap">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="删除权：" FontAttributes="Bold"/>
                                        <Span Text="退出登录可清除会话数据；关闭记住密码功能可删除存储的密码"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <BoxView HeightRequest="20"/>
            </StackLayout>
        </StackLayout>
    </ScrollView>

</ContentPage>
