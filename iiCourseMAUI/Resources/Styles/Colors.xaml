<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- MAUI 默认主题颜色 -->
    <Color x:Key="Primary">#FF6B35</Color>
    <Color x:Key="PrimaryDark">#E55A25</Color>
    <Color x:Key="PrimaryDarkText">#2C3E50</Color>
    <Color x:Key="Secondary">#FFD23F</Color>
    <Color x:Key="SecondaryDarkText">#7F8C8D</Color>
    <Color x:Key="Tertiary">#4ECDC4</Color>
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#F0F0F0</Color>
    <Color x:Key="Gray200">#E8E8E8</Color>
    <Color x:Key="Gray300">#D3D3D3</Color>
    <Color x:Key="Gray400">#BEBEBE</Color>
    <Color x:Key="Gray500">#9E9E9E</Color>
    <Color x:Key="Gray600">#757575</Color>
    <Color x:Key="Gray900">#333333</Color>
    <Color x:Key="Gray950">#141414</Color>
    <Color x:Key="OffBlack">#1F1F1F</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="Magenta">#FF6B35</Color>

    <!-- 自定义颜色资源 - 设计系统 -->
    <Color x:Key="PrimaryColor">#FF6B35</Color>
    <Color x:Key="PrimaryHoverColor">#FF8555</Color>
    <Color x:Key="PrimaryPressedColor">#E55A25</Color>
    <Color x:Key="SecondaryColor">#FFD23F</Color>
    <Color x:Key="AccentColor">#4ECDC4</Color>
    <Color x:Key="BackgroundColor">#FFF8F0</Color>
    <Color x:Key="SidebarBackgroundColor">#FAFAFA</Color>
    <Color x:Key="SidebarActiveColor">#FF6B35</Color>
    <Color x:Key="TextColor">#2C3E50</Color>
    <Color x:Key="SecondaryTextColor">#7F8C8D</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <Color x:Key="SuccessColor">#27AE60</Color>
    <Color x:Key="WarningColor">#F39C12</Color>
    <Color x:Key="ErrorColor">#E74C3C</Color>
    <Color x:Key="BorderColor">#FFE8D6</Color>
    <Color x:Key="HoverBackgroundColor">#FFF5EB</Color>
    <Color x:Key="LightGreenColor">#E8F5E9</Color>
    <Color x:Key="LightYellowColor">#FFF9E6</Color>
    <Color x:Key="LightRedColor">#FFEBEE</Color>
    <Color x:Key="LightBlueColor">#E3F2FD</Color>
    <Color x:Key="DividerColor">#EEEEEE</Color>
    <Color x:Key="InputBorderColor">#E8E8E8</Color>
    <Color x:Key="InputFocusBorderColor">#FF6B35</Color>
    <Color x:Key="TableHeaderColor">#FF6B35</Color>
    <Color x:Key="TableRowEvenColor">#FAFAFA</Color>
    <Color x:Key="TableRowOddColor">#FFFFFF</Color>

    <!-- 画刷资源 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <!-- 渐变画刷 -->
    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF6B35" Offset="0"/>
        <GradientStop Color="#FF8555" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF6B35" Offset="0"/>
        <GradientStop Color="#FF8555" Offset="1"/>
    </LinearGradientBrush>

    <!-- 字体大小 -->
    <x:Double x:Key="FontSizeSmall">12</x:Double>
    <x:Double x:Key="FontSizeNormal">14</x:Double>
    <x:Double x:Key="FontSizeMedium">16</x:Double>
    <x:Double x:Key="FontSizeLarge">20</x:Double>
    <x:Double x:Key="FontSizeTitle">24</x:Double>

    <!-- 圆角 -->
    <CornerRadius x:Key="SmallCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="MediumCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="LargeCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="RoundCornerRadius">36</CornerRadius>

    <!-- 间距 -->
    <Thickness x:Key="SmallPadding">8</Thickness>
    <Thickness x:Key="MediumPadding">16</Thickness>
    <Thickness x:Key="LargePadding">24</Thickness>
    <Thickness x:Key="PagePadding">20</Thickness>

    <!-- 标题标签样式 -->
    <Style x:Key="TitleLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource TextColor}"/>
    </Style>

    <!-- 副标题标签样式 -->
    <Style x:Key="SubtitleLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource FontSizeMedium}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource TextColor}"/>
    </Style>

    <!-- 信息标签样式 -->
    <Style x:Key="InfoLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
        <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}"/>
    </Style>

    <!-- 主要按钮样式 -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeNormal}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="HeightRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryPressedColor}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="#FFD4B8"/>
                            <Setter Property="TextColor" Value="#FFA07A"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- 次要按钮样式 -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource BorderColor}"/>
        <Setter Property="TextColor" Value="{StaticResource PrimaryColor}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeNormal}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="HeightRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="#FFD4B8"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- 输入框样式 -->
    <Style x:Key="EntryStyle" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="White"/>
        <Setter Property="TextColor" Value="{StaticResource TextColor}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource SecondaryTextColor}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeNormal}"/>
        <Setter Property="HeightRequest" Value="44"/>
    </Style>

    <!-- 卡片边框样式 -->
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="White"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource PrimaryBrush}" Offset="0,2" Radius="12" Opacity="0.08"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 页面头部样式 -->
    <Style x:Key="PageHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HeaderGradientBrush}"/>
        <Setter Property="Padding" Value="24,20"/>
    </Style>

    <!-- Frame 卡片样式 -->
    <Style x:Key="CardFrameStyle" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="White"/>
        <Setter Property="BorderColor" Value="{StaticResource BorderColor}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="HasShadow" Value="True"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- Grid 样式 -->
    <Style x:Key="CardGridStyle" TargetType="Grid">
        <Setter Property="RowSpacing" Value="12"/>
        <Setter Property="ColumnSpacing" Value="12"/>
    </Style>

    <!-- 输入框容器样式 -->
    <Style x:Key="InputContainerStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="White"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 8"/>
        <Setter Property="Stroke" Value="{StaticResource InputBorderColor}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Padding" Value="14,12"/>
    </Style>

    <!-- 表格头部样式 -->
    <Style x:Key="TableHeaderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource TableHeaderColor}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 6,6,0,0"/>
    </Style>

    <!-- 表格行样式 -->
    <Style x:Key="TableRowStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="White"/>
        <Setter Property="Padding" Value="10,10"/>
        <Setter Property="Stroke" Value="#F0F0F0"/>
        <Setter Property="StrokeThickness" Value="0,0,0,1"/>
    </Style>

    <!-- 交替行样式 -->
    <Style x:Key="TableRowAlternateStyle" TargetType="Border" BasedOn="{StaticResource TableRowStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource TableRowEvenColor}"/>
    </Style>

</ResourceDictionary>
